{
  "name": "honeybook-hive",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "~24"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "multi-semantic-release --ignore-private-packages --deps.bump=ignore --deps.release=ignore",
    "release:dry": "multi-semantic-release --ignore-private-packages --deps.bump=ignore --deps.release=ignore --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "eslint": "9.31.0",
    "eslint-plugin-import": "2.32.0",
    "globals": "16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "multi-semantic-release": "^3.1.0",
    "prettier": "3.9.1",
    "rimraf": "4.4.1",
    "semantic-release": "^25.0.5",
    "turbo": "2.8.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1"
  }
}
