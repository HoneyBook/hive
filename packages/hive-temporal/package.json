{
  "name": "@honeybook/hive-temporal",
  "version": "0.1.0-beta.5",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@honeybook/hive": "workspace:*",
    "@honeybook/hive-runner": "workspace:*",
    "@temporalio/testing": "1.18.1",
    "@temporalio/worker": "1.18.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.2.0",
    "rimraf": "catalog:",
    "ts-jest": "29.4.5",
    "typescript": "6.0.3"
  }
}
