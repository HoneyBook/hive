{
  "name": "@honeybook/hive",
  "version": "1.5.0",
  "description": "HoneyBook test kits infrastructure for building structured testing frameworks",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoneyBook/hive.git",
    "directory": "packages/hive"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -b && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "lodash-es": "catalog:",
    "type-fest": "catalog:"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/lodash-es": "4.17.12",
    "@types/lodash": "catalog:",
    "jest": "30.2.0",
    "rimraf": "catalog:",
    "ts-jest": "29.4.5",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  }
}
