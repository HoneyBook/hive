{
  "name": "@honeybook/hive-mock-adapter-vitest",
  "version": "0.1.1",
  "description": "Vitest plugin for hive-mock-adapter — vi.spyOn-backed mock substitution.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoneyBook/hive.git",
    "directory": "packages/hive-mock-adapter-vitest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "import": "./dist/src/setup.js",
      "types": "./dist/src/setup.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@honeybook/hive-mock-adapter": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=1"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "rimraf": "catalog:",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
