{
  "name": "@honeybook/hive-react",
  "version": "0.0.0",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "restricted" },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@honeybook/hive": "workspace:*",
    "@honeybook/hive-runner": "workspace:*",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "@testing-library/react": ">=11",
    "react": ">=17"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/jest": "30.0.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rimraf": "catalog:",
    "ts-jest": "29.4.5",
    "typescript": "6.0.3"
  }
}
