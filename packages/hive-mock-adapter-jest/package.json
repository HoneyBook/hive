{
  "name": "@honeybook/hive-mock-adapter-jest",
  "version": "0.1.0",
  "description": "Jest plugin for hive-mock-adapter — jest.spyOn-backed mock substitution.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoneyBook/hive.git",
    "directory": "packages/hive-mock-adapter-jest"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./setup": {
      "import": "./dist/src/setup.js",
      "require": "./dist/cjs/src/setup.js",
      "types": "./dist/src/setup.d.ts"
    },
    "./resolver": "./resolver.cjs"
  },
  "files": [
    "dist",
    "resolver.cjs"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@honeybook/hive-mock-adapter": "workspace:*"
  },
  "peerDependencies": {
    "jest": ">=29"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "jest": "30.2.0",
    "rimraf": "catalog:",
    "typescript": "6.0.3"
  }
}
