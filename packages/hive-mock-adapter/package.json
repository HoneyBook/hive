{
  "name": "@honeybook/hive-mock-adapter",
  "version": "0.1.0-beta.0",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "rimraf": "catalog:",
    "typescript": "6.0.3"
  }
}
