{
  "name": "@honeybook/hive-kit-indexer",
  "version": "0.1.0",
  "description": "Generates a kit-index.json manifest of a hive package's TestKit/AsyncTestKit subclasses, their with* methods, and runner forced-base-kits — for downstream consumers like skill-ladder generators.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoneyBook/hive.git",
    "directory": "packages/hive-kit-indexer"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "hive-kit-indexer": "./dist/cjs/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.cloudsmith.io/honeybook/npmjs/"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json && tsc --project tsconfig.cjs.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "ts-morph": "28.0.0"
  },
  "devDependencies": {
    "@honeybook/hive": "workspace:*",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "jest": "30.2.0",
    "rimraf": "catalog:",
    "ts-jest": "29.4.5",
    "typescript": "6.0.3"
  }
}
